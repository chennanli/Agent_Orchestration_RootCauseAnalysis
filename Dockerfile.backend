# ==============================================================================
# TEP Backend Dockerfile
# ==============================================================================
# Purpose: FastAPI backend with embedded TEP simulation (Fortran), LLM clients, RAG
# Architecture: Monolithic (matches current design)
# Platform: Linux (rebuilds Fortran modules from source)
# ==============================================================================

# Stage 1: Build Fortran modules
FROM python:3.12-slim AS fortran-builder

# Install Fortran compiler and build tools
RUN apt-get update && apt-get install -y \
    gfortran \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build

# Copy Fortran wrapper Python files. We DO NOT attempt to rebuild Fortran
# inside Docker — the .so binary is precompiled per host architecture and
# shipped in backend/simulation/. The `RUN if [ -f "*.f90" ]` line that
# used to be here tested the literal string "*.f90" (no glob expansion in
# `[ -f ... ]`) and would always be false, so the rebuild never ran.
COPY backend/simulation/*.py ./simulation/

# ==============================================================================
# Stage 2: Production runtime
# ==============================================================================
FROM python:3.12-slim

WORKDIR /app

# Install runtime dependencies for compiled modules
RUN apt-get update && apt-get install -y \
    libgfortran5 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements and install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code. Both `RAG/` and `knowledge_base/` are needed:
#   - `RAG/converted_markdown/*.md` is what the agent's `search_process_knowledge`
#     tool actually reads (the keyword index). EnhancedKnowledgeManager defaults
#     to this path when no path is passed in.
#   - `knowledge_base/` holds the original PDFs/DOCX (source-of-truth) plus
#     anything users have uploaded via /rag/upload_build for re-conversion.
COPY backend/ ./backend/
COPY config/ ./config/
COPY RAG/ ./RAG/
COPY knowledge_base/ ./knowledge_base/

# Copy the prebuilt Fortran .so files. The old form
#   COPY backend/simulation/*.so ./backend/simulation/ 2>/dev/null || true
# is INVALID — Dockerfile COPY does not honour shell redirection or `||`.
# Linux NIM/TEP support requires the linux-gnu .so to be present in the repo;
# we still ship it (`temain_mod.cpython-36m-x86_64-linux-gnu.so`).
COPY backend/simulation/temain_mod.cpython-36m-x86_64-linux-gnu.so ./backend/simulation/

# Create necessary directories
RUN mkdir -p \
    /app/data \
    /app/RCA_Results \
    /app/backend/diagnostics \
    /app/backend/LLM_RCA_Results \
    /app/backend/logs

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/ || exit 1

# Expose port
EXPOSE 8000

# Run FastAPI with uvicorn
CMD ["uvicorn", "backend.app:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]


# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
tep_env/

# Re-include the prebuilt Linux Fortran extension for the TEP simulator —
# Dockerfile.backend + Dockerfile.console BOTH COPY this file by name, so it
# must survive the generic *.so exclude above. (The darwin .so variants stay
# excluded — they're built per-host and only used outside Docker.)
!backend/simulation/temain_mod.cpython-36m-x86_64-linux-gnu.so

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Git
.git/
.gitignore
.gitattributes

# Documentation (don't need in container)
*.md
!README.md
# Critical: the agent's `search_process_knowledge` tool reads
# RAG/converted_markdown/*.md AT RUNTIME inside the container. Without this
# re-include, the generic `*.md` rule above strips those files out of the
# Docker build context and the keyword/hybrid wiki search returns 0 hits.
!RAG/converted_markdown/*.md
docs/
image/

# Logs and temporary files
*.log
*.log.*
logs/
backend/logs/

# Test files
tests/
*.test.js
*.spec.js

# Build artifacts (will be rebuilt in container)
dist/
build/
*.egg-info/

# Data files (will be mounted as volumes)
data/
RCA_Results/
backend/diagnostics/
backend/LLM_RCA_Results/

# Scripts (not needed in container)
*.command
*.sh
SETUP_*.command
START_ALL.command
STOP_ALL.command

# Config templates (use .env instead)
.env.template
config.template.json

# ---------------------------------------------------------------------------
# Secrets & local-only tooling — MUST NOT enter the Docker build context.
# This block mirrors the analogous protections in .gitignore. Even though
# the current Dockerfiles copy explicit subtrees rather than the whole
# tree, a remote builder (`docker buildx` / GHA runner) still receives
# the full build context before the COPY filter runs — so anything an
# attacker could exfiltrate from build logs lives here, and these
# patterns short-circuit that path.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.template
**/.env
**/.env.*
**/.env.local
*.env

# Local agent / IDE scratch state
.claude/
.codex/
.roomodes
.serena/
.cursor/
.aider*
.windsurf/

# Local Python / venv state (already largely covered above, but explicit)
.venv/
venv/
__pycache__/
*.py[cod]

# Local diagnostic dumps & saved runs (not part of any shipped artefact)
backend/diagnostics/
backend/LLM_RCA_Results/

